__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env_/
ENV/

# ── Testing & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

